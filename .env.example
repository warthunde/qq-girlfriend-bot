# =============================================================
# 纽带乐队四人组 — 环境变量配置模板
# 复制此文件为 .env 并填入你的配置
#   cp .env.example .env
# =============================================================

# ============================================================
# 四个 QQ 号（每个需要独立注册）
# ============================================================
# 虹夏 — 伊地知虹夏，鼓手兼队长
NIJIKA_QQ=1234567890

# 波奇酱 — 后藤一里，主音吉他手（社恐）
BOCCHI_QQ=1234567891

# 山田凉 — 贝斯手（cool系/残念）
RYO_QQ=1234567892

# 喜多郁代 — 主唱兼吉他手（开朗）
KITA_QQ=1234567893

# ============================================================
# DeepSeek API（四个 Bot 共用）
# 在 https://platform.deepseek.com 获取
# ============================================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ============================================================
# 目标 QQ 群（四个 Bot 必须都在这个群里）
# ============================================================
TARGET_GROUP_ID=123456789

# ============================================================
# 自定义端口（可选，以下为默认值）
# ============================================================
# 虹夏
# NIJIKA_WS_PORT=3001
# NIJIKA_HTTP_PORT=3010
# NIJIKA_WEBUI_PORT=6100

# 波奇酱
# BOCCHI_WS_PORT=3002
# BOCCHI_HTTP_PORT=3020
# BOCCHI_WEBUI_PORT=6101

# 山田凉
# RYO_WS_PORT=3003
# RYO_HTTP_PORT=3030
# RYO_WEBUI_PORT=6102

# 喜多郁代
# KITA_WS_PORT=3004
# KITA_HTTP_PORT=3040
# KITA_WEBUI_PORT=6103

# ============================================================
# 小剧场设置（可选，以下为默认值）
# ============================================================
# 小剧场触发间隔（分钟）
# THEATER_INTERVAL_MIN=30
# THEATER_INTERVAL_MAX=60

# 小剧场中每条消息的间隔（秒）
# MESSAGE_INTERVAL_MIN=5
# MESSAGE_INTERVAL_MAX=20

# ============================================================
# 人类回复设置（可选，以下为默认值）
# ============================================================
# 回复延迟（秒）
# HUMAN_REPLY_DELAY_MIN=3
# HUMAN_REPLY_DELAY_MAX=8

# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# ============================================================
# （可选）原有 AstrBot 独立虹夏 Bot
# 如需同时运行 AstrBot: docker compose --profile astrbot up -d
# ============================================================
# BOT_NICKNAME=小染
# TAVILY_API_KEY=你的Tavily Key
