# =============================================================
# QQ 赛博女友 - 环境变量配置模板
# 复制此文件为 .env 并填入你的信息
#   cp .env.example .env
# =============================================================

# ---- QQ 账号配置 ----
# 用于登录的 QQ 号（建议使用小号）
QQ_ACCOUNT=1234567890

# ---- AI 模型配置 ----
# AI 提供商：deepseek（推荐）或 openai
AI_PROVIDER=deepseek

# DeepSeek API Key（在 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI API Key（仅在使用 OpenAI 时需要）
OPENAI_API_KEY=

# AI 模型名称
# DeepSeek: deepseek-chat（推荐）或 deepseek-reasoner
# OpenAI: gpt-4o, gpt-4o-mini
AI_MODEL=deepseek-chat

# DeepSeek API 地址（默认官方地址，可切换国内代理）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- 机器人基础配置 ----
# 机器人昵称（在群聊/私聊中的名字）
BOT_NICKNAME=小染

# ---- 行为配置 ----
# 回复延迟范围（秒），模拟真人打字思考
REPLY_DELAY_MIN=3
REPLY_DELAY_MAX=8

# 是否模拟打字效果（true/false）
SIMULATE_TYPING=true

# ---- NapCat 配置 ----
# WebSocket Token（可选，用于 AstrBot 与 NapCat 之间的鉴权，留空不校验）
# 如果填写，需要与 NapCat 端配置一致
NAPAT_WS_TOKEN=

# ---- 黑名单/白名单配置（可选）----
# 允许使用机器人的群号，多个用逗号分隔（留空 = 所有群）
ALLOWED_GROUP_IDS=

# 禁止使用机器人的群号，多个用逗号分隔
BLOCKED_GROUP_IDS=

# 允许使用机器人的用户 QQ 号，多个用逗号分隔（留空 = 所有用户）
ALLOWED_USER_IDS=

# ---- 网络搜索配置（Tavily）----
# 注册获取免费 Key：https://tavily.com
TAVILY_API_KEY=
